<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
 <BehaviorTree ID="rmuc_2026_sentry">
    <!-- 总闸：比赛阶段 4 + 剩余时间 0~420s -->
    <Sequence>
      <IsGameStatus max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>
      <Sequence>
        <!-- ===== 阶段一（一次性）：首点压制 → 补给 ===== -->
        <Sequence>
          <!-- 首点 (5.90, 4.15): 弹丸 >= 1 且 血量 >= 150 时停留; 弹丸 == 0 或 血量 < 150 时离开 -->
          <RetryUntilSuccessful num_attempts="-1">
            <Sequence>
              <PubGoal goal_pose_x="5.90"
                       goal_pose_y="4.15"
                       topic_name="/goal_pose"/>
              <Fallback>
                <Inverter>
                  <IsStatusOK ammo_min="1"
                              hp_min="0"
                              key_port="{@referee_robotStatus}"/>
                </Inverter>
                <Inverter>
                  <IsStatusOK ammo_min="0"
                              hp_min="150"
                              key_port="{@referee_robotStatus}"/>
                </Inverter>
              </Fallback>
            </Sequence>
          </RetryUntilSuccessful>

          <!-- 补给区 (-0.94, -5.01)：弹丸 >= 50 且 血量 >= 400 才离开 -->
          <RetryUntilSuccessful num_attempts="-1">
            <Sequence>
              <PubGoal goal_pose_x="-0.94"
                       goal_pose_y="-5.01"
                       topic_name="/goal_pose"/>
              <Sequence>
                <IsStatusOK ammo_min="50"
                            hp_min="0"
                            key_port="{@referee_robotStatus}"/>
                <IsStatusOK ammo_min="0"
                            hp_min="400"
                            key_port="{@referee_robotStatus}"/>
              </Sequence>
            </Sequence>
          </RetryUntilSuccessful>
        </Sequence>

        <!-- ===== 阶段二（循环至比赛结束）：次点驻守 ↔ 补给 ===== -->
        <KeepRunningUntilFailure>
          <WhileDoElse>
            <!-- 安全条件: 弹丸 >= 1 且 血量 >= 150 -->
            <IsStatusOK ammo_min="1"
                        hp_min="150"
                        key_port="{@referee_robotStatus}"/>

            <!-- 驻守次点 (5.56, -3.02) -->
            <Sequence>
              <PubGoal goal_pose_x="5.56"
                       goal_pose_y="-3.02"
                       topic_name="/goal_pose"/>
              <Sleep msec="200"/>
            </Sequence>

            <!-- 弹丸 == 0 或 血量 < 150：回补给区，补满后再回次点 -->
            <RetryUntilSuccessful num_attempts="-1">
              <Sequence>
                <PubGoal goal_pose_x="-0.94"
                         goal_pose_y="-5.01"
                         topic_name="/goal_pose"/>
                <Sequence>
                  <IsStatusOK ammo_min="50"
                              hp_min="0"
                              key_port="{@referee_robotStatus}"/>
                  <IsStatusOK ammo_min="0"
                              hp_min="400"
                              key_port="{@referee_robotStatus}"/>
                </Sequence>
              </Sequence>
            </RetryUntilSuccessful>
          </WhileDoElse>
        </KeepRunningUntilFailure>
      </Sequence>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="BattlefieldInformation"
            editable="true">
      <input_port name="key_port"
                  default="{@referee_allRobotHP}"/>
      <output_port name="weight"/>
    </Action>
    <Condition ID="IsGameStatus"
               editable="true">
      <input_port name="max_remain_time"
                  default="420">Maximum remaining time (s)</input_port>
      <input_port name="min_remain_time"
                  default="0">Minimum remaining time (s)</input_port>
      <input_port name="expected_game_progress"
                  default="4">Expected game progress stage</input_port>
      <input_port name="key_port"
                  default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
    </Condition>
    <Condition ID="IsAllyBaseHpLow"
               editable="true">
      <input_port name="key_port"
                  default="{@referee_allRobotHP}"/>
      <input_port name="threshold"
                  default="5000"/>
    </Condition>
    <Condition ID="IsEnemyFortressOccupied"
               editable="true">
      <input_port name="key_port"
                  default="{@referee_allRobotHP}"/>
    </Condition>
    <Condition ID="IsOutpostOk"
               editable="true">
      <input_port name="key_port"
                  default="{@referee_allRobotHP}"/>
    </Condition>
    <Condition ID="IsRfidDetected">
      <input_port name="friendly_supply_zone_exchange"
                  default="false"
                  type="bool">己方与兑换区重叠的补给区</input_port>
      <input_port name="friendly_supply_zone_non_exchange"
                  default="false"
                  type="bool">己方与兑换区不重叠的补给区 / RMUL 补给区</input_port>
      <input_port name="center_gain_point"
                  default="false"
                  type="bool">中心增益点（仅 RMUL 适用）</input_port>
      <input_port name="friendly_fortress_gain_point"
                  default="false"
                  type="bool">己方堡垒增益点</input_port>
      <input_port name="key_port"
                  default="{@referee_rfidStatus}"
                  type="rm_interfaces::msg::RfidStatus_&lt;std::allocator&lt;void&gt; &gt;">RfidStatus port on blackboard</input_port>
    </Condition>
    <Condition ID="IsStatusOK">
      <input_port name="ammo_min"
                  default="0"
                  type="int">Lower than minimum ammo will return FAILURE</input_port>
      <input_port name="ammo_max"
                  default="65535"
                  type="int">Higher than maximum ammo will return FAILURE</input_port>
      <input_port name="hp_min"
                  default="300"
                  type="int">Minimum HP. NOTE: Sentry init/max HP is 400</input_port>
      <input_port name="key_port"
                  default="{@referee_robotStatus}"
                  type="rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;">RobotStatus port on blackboard</input_port>
    </Condition>
    <Action ID="PubGoal"
            editable="true">
      <input_port name="goal_pose_x"/>
      <input_port name="goal_pose_y"/>
      <input_port name="topic_name"
                  default="/goal_pose"/>
    </Action>
    <Action ID="Pursuit"
            editable="true">
      <input_port name="key_port"
                  default="{@tracker_target}"/>
      <input_port name="topic_name"
                  default="/goal_pose"/>
    </Action>
  </TreeNodesModel>

</root>
