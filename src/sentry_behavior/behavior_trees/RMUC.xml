                   topic_name="/goal_pose"/>
          <Sleep msec="10000"/>
          <PubGoal goal_pose_x="4.24"
                   goal_pose_y="-2.54"
                   topic_name="/goal_pose"/>
          <Sleep msec="15000"/>
          <PubGoal goal_pose_x="3.85"
                   goal_pose_y="2.58"
                   topic_name="/goal_pose"/>
          <Sleep msec="10000"/>
        </Sequence>
        <WhileDoElse>
          <IsRfidDetected friendly_supply_zone_exchange="false"
                          friendly_supply_zone_non_exchange="true"
                          center_gain_point="false"
                          friendly_fortress_gain_point="false"
                          key_port="{@referee_rfidStatus}"/>
          <Sleep msec="6000"/>
          <PubGoal goal_pose_x="-1.02"
                   goal_pose_y="-4.91"
