  <BehaviorTree ID="rmuc1">
    <Sequence>
      <WhileDoElse>
        <IsStatusOK ammo_min="0"
                    heat_max="350"
                    hp_min="100"
                    key_port="{@referee_robotStatus}"/>
        <Sequence>
          <IsStatusOK ammo_min="0"
                      heat_max="350"
                      hp_min="400"
                      key_port="{@referee_robotStatus}"/>
          <PubGoal goal_pose_x="13.6"
                   goal_pose_y="-1.31"
                   topic_name="/goal_pose"/>
        </Sequence>
        <PubGoal goal_pose_x="-0.29"
                 goal_pose_y="-7.37"
                 topic_name="/goal_pose"/>
      </WhileDoElse>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="rmuc2">
    <Sequence>
      <Pursuit key_port="{@tracker_target}"
