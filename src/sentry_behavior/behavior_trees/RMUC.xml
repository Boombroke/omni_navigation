<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="rmuc_defend">
    <!-- 防守守家策略 — 多场比赛永循环:
         KeepRunningUntilFailure: child SUCCESS -> resetChild + RUNNING -> 等下一场;
                                  child FAILURE -> 整树 FAILURE 退出.

         一场赛 = Sequence:
           1) 等比赛开始 (progress=4, 420~0s)
           2) ReactiveFallback: 守家决策 + 比赛结束检测

         守家逻辑:
           - 非致命 (HP>150 且 ammo>0) -> 驻守防守点
           - 致命 (HP<=150 或 ammo==0) -> 回补给区
           - 补满 (HP>=400 且 ammo>=50) -> 返回防守点
           - 滞回: 退出防守门槛低, 重新进入门槛高, 避免振荡 -->

    <KeepRunningUntilFailure>
      <Sequence>

        <!-- ===== 等待比赛开始 ===== -->
        <RetryUntilSuccessful num_attempts="-1">
          <Delay delay_msec="500">
            <IsGameStatus max_remain_time="420"
                          min_remain_time="0"
                          expected_game_progress="4"
                          key_port="{@referee_gameStatus}"/>
          </Delay>
        </RetryUntilSuccessful>

        <!-- ===== 比赛中 ===== -->
        <ReactiveFallback>
          <!-- 比赛结束: progress != 4 -> SUCCESS -> 一场赛结束 -> 外层重置等下一场 -->
          <Inverter>
            <IsGameStatus max_remain_time="420"
                          min_remain_time="0"
                          expected_game_progress="4"
                          key_port="{@referee_gameStatus}"/>
          </Inverter>

          <!-- 主决策: 守点 <-> 补给 -->
          <KeepRunningUntilFailure>
            <ReactiveSequence>
              <IsGameStatus max_remain_time="420"
                            min_remain_time="0"
                            expected_game_progress="4"
                            key_port="{@referee_gameStatus}"/>

              <KeepRunningUntilFailure>

                <WhileDoElse>
                  <!-- 条件: HP > 150 且 ammo > 0 -> 驻守防守点 -->
                  <IsStatusOK ammo_min="1"
                              ammo_max="65535"
                              hp_min="151"
                              key_port="{@referee_robotStatus}"/>
                  <!-- do_A: 防守点 -->
                  <KeepRunningUntilFailure>
                    <PubGoal topic_name="/goal_pose"
                             goal_pose_x="3.71"
                             goal_pose_y="-0.61"
                             goal_pose_yaw="0.0"/>
                  </KeepRunningUntilFailure>
                  <!-- do_B: ammo==0 或 HP<=150 -> 回补给 -->
                  <WhileDoElse>
                    <!-- 条件: HP >= 400 且 ammo >= 50 -> 已补满, 回防守点 -->
                    <IsStatusOK ammo_min="50"
                                ammo_max="65535"
                                hp_min="400"
                                key_port="{@referee_robotStatus}"/>
                    <!-- do_A: 返回防守点 -->
                    <KeepRunningUntilFailure>
                      <PubGoal topic_name="/goal_pose"
                               goal_pose_x="3.71"
                               goal_pose_y="-0.61"
                               goal_pose_yaw="0.0"/>
                    </KeepRunningUntilFailure>
                    <!-- do_B: 继续补给 -->
                    <KeepRunningUntilFailure>
                      <PubGoal topic_name="/goal_pose"
                               goal_pose_x="-0.27"
                               goal_pose_y="-3.94"
                               goal_pose_yaw="0.0"/>
                    </KeepRunningUntilFailure>
                  </WhileDoElse>
                </WhileDoElse>

              </KeepRunningUntilFailure>
            </ReactiveSequence>
          </KeepRunningUntilFailure>
        </ReactiveFallback>

      </Sequence>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="IsGameStatus"
               editable="true">
      <input_port name="max_remain_time"
                  default="420">Maximum remaining time (s)</input_port>
      <input_port name="min_remain_time"
                  default="0">Minimum remaining time (s)</input_port>
      <input_port name="expected_game_progress"
                  default="4">Expected game progress stage</input_port>
      <input_port name="key_port"
                  default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
    </Condition>
    <Condition ID="IsStatusOK">
      <input_port name="ammo_min"
                  default="0"
                  type="int">ammo &lt; ammo_min returns FAILURE</input_port>
      <input_port name="ammo_max"
                  default="65535"
                  type="int">ammo &gt; ammo_max returns FAILURE</input_port>
      <input_port name="hp_min"
                  default="300"
                  type="int">HP &lt; hp_min returns FAILURE</input_port>
      <input_port name="key_port"
                  default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
    </Condition>
    <Action ID="PubGoal"
            editable="true">
      <input_port name="topic_name"
                  default="/goal_pose">PoseStamped topic to publish</input_port>
      <input_port name="goal_pose_x"/>
      <input_port name="goal_pose_y"/>
      <input_port name="goal_pose_yaw"
                  default="0.0"
                  type="float">目标航向 (rad)</input_port>
    </Action>
  </TreeNodesModel>

</root>
