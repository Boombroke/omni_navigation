<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="blue">
    <Sequence>
      <IsGameStatus max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"
                    state="{@state}"/>
      <Switch3 case_1="1.0"
               case_2="2.0"
               case_3="3.0"
               variable="{@state}">
        <SubTree ID="blue_down_1"
                 _autoremap="true"/>
        <SubTree ID="blue_down_2"
                 _autoremap="true"/>
        <SubTree ID="blue_up"
                 _autoremap="true"/>
        <Sleep msec="1111"/>
      </Switch3>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="blue_down_1">
    <WhileDoElse>
      <IsStatusOK ammo_min="1"
                  heat_max="350"
                  hp_min="200"
                  key_port="{@referee_robotStatus}"/>
      <Sequence>
        <PubGoal goal_pose_x="5.7"
                 goal_pose_y="6.8"
                 topic_name="/goal_pose"/>
        <Sleep msec="13000"/>
        <PubGoal goal_pose_x="4.9"
                 goal_pose_y="-2.3"
                 topic_name="/goal_pose"/>
        <Sleep msec="10000"/>
        <PubGoal goal_pose_x="4.6"
                 goal_pose_y="1.7"
                 topic_name="/goal_pose"/>
        <Sleep msec="11000"/>
      </Sequence>
      <WhileDoElse>
        <IsRfidDetected friendly_supply_zone_exchange="false"
                        friendly_supply_zone_non_exchange="true"
                        center_gain_point="false"
                        friendly_fortress_gain_point="false"
                        key_port="{@referee_rfidStatus}"/>
        <Sleep msec="6000"/>
        <PubGoal goal_pose_x="-1.05"
                 goal_pose_y="-4.97"
                 topic_name="/goal_pose"/>
      </WhileDoElse>
    </WhileDoElse>
  </BehaviorTree>

  <BehaviorTree ID="blue_down_2">
    <WhileDoElse>
      <IsStatusOK ammo_min="1"
                  heat_max="350"
                  hp_min="150"
                  key_port="{@referee_robotStatus}"/>
      <PubGoal goal_pose_x="5.5"
               goal_pose_y="7.7"
               topic_name="/goal_pose"/>
      <WhileDoElse>
        <IsRfidDetected friendly_supply_zone_exchange="false"
                        friendly_supply_zone_non_exchange="true"
                        center_gain_point="false"
                        friendly_fortress_gain_point="false"
                        key_port="{@referee_rfidStatus}"/>
        <Sleep msec="6000"/>
        <PubGoal goal_pose_x="-1.05"
                 goal_pose_y="-5.46"
                 topic_name="/goal_pose"/>
      </WhileDoElse>
    </WhileDoElse>
  </BehaviorTree>

  <BehaviorTree ID="blue_up">
    <WhileDoElse>
      <IsOutpostOk key_port="{@referee_allRobotHP}"/>
      <WhileDoElse>
        <IsStatusOK ammo_min="1"
                    heat_max="350"
                    hp_min="200"
                    key_port="{@referee_robotStatus}"/>
        <PubGoal goal_pose_x="12.07"
                 goal_pose_y="-0.76"
                 topic_name="/goal_pose"/>
        <WhileDoElse>
          <IsRfidDetected friendly_supply_zone_exchange="false"
                          friendly_supply_zone_non_exchange="true"
                          center_gain_point="false"
                          friendly_fortress_gain_point="false"
                          key_port="{@referee_rfidStatus}"/>
          <Sleep msec="4000"/>
          <PubGoal goal_pose_x="8.05"
                   goal_pose_y="-2.89"
                   topic_name="/goal_pose"/>
        </WhileDoElse>
      </WhileDoElse>
      <WhileDoElse>
        <IsStatusOK ammo_min="1"
                    heat_max="350"
                    hp_min="200"
                    key_port="{@referee_robotStatus}"/>
        <PubGoal goal_pose_x="12.07"
                 goal_pose_y="-0.76"
                 topic_name="/goal_pose"/>
        <WhileDoElse>
          <IsRfidDetected friendly_supply_zone_exchange="false"
                          friendly_supply_zone_non_exchange="true"
                          center_gain_point="false"
                          friendly_fortress_gain_point="false"
                          key_port="{@referee_rfidStatus}"/>
          <Sleep msec="6000"/>
          <PubGoal goal_pose_x="-1.05"
                   goal_pose_y="-4.97"
                   topic_name="/goal_pose"/>
        </WhileDoElse>
      </WhileDoElse>
    </WhileDoElse>
  </BehaviorTree>

  <BehaviorTree ID="red">
    <Sequence>
      <IsGameStatus max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"
                    state="{@state}"/>
      <Switch3 case_1="1.0"
               case_2="2.0"
               case_3="3.0"
               variable="{@state}">
        <SubTree ID="red_down"
                 _autoremap="true"/>
        <SubTree ID="red_down_2"
                 _autoremap="true"/>
        <SubTree ID="red_up"
                 _autoremap="true"/>
        <Sleep msec="10000"/>
      </Switch3>
    </Sequence>
  </BehaviorTree>

