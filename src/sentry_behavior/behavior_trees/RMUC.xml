  <BehaviorTree ID="rmuc_no">
    <Sequence>
      <BattlefieldInformation key_port="{@referee_allRobotHP}"
                              weight="{@weight}"/>
      <WhileDoElse>
        <IsStatusOK ammo_min="1"
                    heat_max="350"
                    hp_min="180"
                    key_port="{@referee_robotStatus}"/>
        <Switch3 case_1="1.0"
                 case_2="2.0"
                 case_3="0.0"
                 variable="{@weight}">
          <PubGoal goal_pose_x="11.76"
                   goal_pose_y="-0.17"
                   topic_name="/goal_pose"/>
          <PubGoal goal_pose_x="14.35"
                   goal_pose_y="2.61"
                   topic_name="/goal_pose"/>
          <PubGoal goal_pose_x="8.59"
                   goal_pose_y="-4.34"
                   topic_name="/goal_pose"/>
          <PubGoal goal_pose_x="4.85"
                   goal_pose_y="-0.75"
                   topic_name="/goal_pose"/>
        </Switch3>
        <WhileDoElse>
          <IsRfidDetected friendly_supply_zone_exchange="false"
                          friendly_supply_zone_non_exchange="true"
                          center_gain_point="false"
                          friendly_fortress_gain_point="false"
                          key_port="{@referee_rfidStatus}"/>
          <Sleep msec="4000"/>
          <PubGoal goal_pose_x="0.68"
                   goal_pose_y="-3.64"
                   topic_name="/goal_pose"/>
        </WhileDoElse>
      </WhileDoElse>
    </Sequence>
  </BehaviorTree>

