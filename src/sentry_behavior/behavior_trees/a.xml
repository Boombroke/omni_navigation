<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <BehaviorTree ID="a">
    <!-- 多场比赛永循环外壳 (与 b.xml 同构):
         外层 KeepRunningUntilFailure: 一场赛 SUCCESS 后 reset+RUNNING 重启等下一场.

         一场赛 = Sequence:
           1) RetryUntilSuccessful + Delay(500ms): 等比赛开始, 限速避免 RetryNode spam.
              GameStatus 缺失 / progress!=4 -> IsGameStatus FAILURE -> Delay 等 500ms -> retry.
              progress==4 -> SUCCESS -> Delay SUCCESS -> 推进.
           2) ReactiveFallback: 比赛中
              首项 Inverter(IsGameStatus): progress 翻非 4 时 SUCCESS -> 一场赛 SUCCESS -> 重启等下一场.
              次项 KeepRunning(主决策): 比赛中持续 publish goal.

         主决策为 Fallback (优先攻击, 次之补给), Fallback 内部用 ReactiveSequence
         强制每 tick 重判 condition, 避免 BT.CPP 4 默认 Sequence with-memory 在
         "hp 跌至阈值下"瞬间没有立刻让 condition 重新求值的 corner case.

         阈值:
           - 攻击需 ammo>=1 且 hp>=300 (放宽自原 hp>=150 的攻击门槛, 与"回家"门槛
             更靠近, 减小迟滞带宽; 哨兵血量 350 这种离散值不会卡死).
           - 不满足任一即去补给点, 在补给点期间血/弹补回 ammo>=1 且 hp>=300 后
             自动回攻击层 (ReactiveSequence 每 tick 重判, 不需要二阈值出口). -->
    <KeepRunningUntilFailure>
      <Sequence>
        <RetryUntilSuccessful num_attempts="-1">
          <Delay delay_msec="500">
            <IsGameStatus max_remain_time="420"
                          min_remain_time="0"
                          expected_game_progress="4"
                          key_port="{@referee_gameStatus}"/>
          </Delay>
        </RetryUntilSuccessful>
        <ReactiveFallback>
          <Inverter>
            <IsGameStatus max_remain_time="420"
                          min_remain_time="0"
                          expected_game_progress="4"
                          key_port="{@referee_gameStatus}"/>
          </Inverter>
          <KeepRunningUntilFailure>
            <Fallback>
              <!-- 优先: ammo>=1 && hp>=300 -> 攻击点 -->
              <ReactiveSequence>
                <IsStatusOK ammo_min="1"
                            ammo_max="65535"
                            hp_min="300"
                            key_port="{@referee_robotStatus}"/>
                <PubGoal topic_name="/goal_pose"
                         goal_pose_x="3.71"
                         goal_pose_y="-0.61"
                         goal_pose_yaw="0.0"/>
              </ReactiveSequence>

              <!-- 兜底: 任一阈值不满足 -> 补给点 -->
              <PubGoal topic_name="/goal_pose"
                       goal_pose_x="-0.27"
                       goal_pose_y="-3.94"
                       goal_pose_yaw="0.0"/>
            </Fallback>
          </KeepRunningUntilFailure>
        </ReactiveFallback>
      </Sequence>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Condition ID="IsGameStatus"
               editable="true">
      <input_port name="max_remain_time"
                  default="420">Maximum remaining time (s)</input_port>
      <input_port name="min_remain_time"
                  default="0">Minimum remaining time (s)</input_port>
      <input_port name="expected_game_progress"
                  default="4">Expected game progress stage</input_port>
      <input_port name="key_port"
                  default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
    </Condition>
    <Condition ID="IsStatusOK">
      <input_port name="ammo_min"
                  default="0"
                  type="int">ammo &lt; ammo_min returns FAILURE</input_port>
      <input_port name="ammo_max"
                  default="65535"
                  type="int">ammo &gt; ammo_max returns FAILURE</input_port>
      <input_port name="hp_min"
                  default="300"
                  type="int">HP &lt; hp_min returns FAILURE</input_port>
      <input_port name="key_port"
                  default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
    </Condition>
    <Action ID="PubGoal"
            editable="true">
      <input_port name="topic_name"
                  default="/goal_pose">PoseStamped topic to publish</input_port>
      <input_port name="goal_pose_x"/>
      <input_port name="goal_pose_y"/>
      <input_port name="goal_pose_yaw"
                  default="0.0"
                  type="float">目标航向 (rad)</input_port>
    </Action>
  </TreeNodesModel>

</root>
